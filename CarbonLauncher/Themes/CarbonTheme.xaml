<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="CarbonBackgroundColor">#07080D</Color>
    <Color x:Key="CarbonSurfaceColor">#0D1220</Color>
    <Color x:Key="CarbonPanelColor">#121A2E</Color>
    <Color x:Key="CarbonPanelLightColor">#18233D</Color>
    <Color x:Key="CarbonPinkColor">#FF4FA3</Color>
    <Color x:Key="CarbonBlueColor">#4DA6FF</Color>
    <Color x:Key="CarbonCyanColor">#6EE7FF</Color>
    <Color x:Key="CarbonTextColor">#FFFFFF</Color>
    <Color x:Key="CarbonMutedTextColor">#A8B0C2</Color>
    <Color x:Key="CarbonBorderColor">#26324D</Color>

    <SolidColorBrush x:Key="CarbonBackgroundBrush" Color="{StaticResource CarbonBackgroundColor}" />
    <SolidColorBrush x:Key="CarbonSurfaceBrush" Color="{StaticResource CarbonSurfaceColor}" />
    <SolidColorBrush x:Key="CarbonSidebarBrush" Color="#090D18" />
    <SolidColorBrush x:Key="CarbonPanelBrush" Color="{StaticResource CarbonPanelColor}" />
    <SolidColorBrush x:Key="CarbonPanelLightBrush" Color="{StaticResource CarbonPanelLightColor}" />
    <SolidColorBrush x:Key="CarbonPinkBrush" Color="{StaticResource CarbonPinkColor}" />
    <SolidColorBrush x:Key="CarbonBlueBrush" Color="{StaticResource CarbonBlueColor}" />
    <SolidColorBrush x:Key="CarbonCyanBrush" Color="{StaticResource CarbonCyanColor}" />
    <SolidColorBrush x:Key="CarbonTextBrush" Color="{StaticResource CarbonTextColor}" />
    <SolidColorBrush x:Key="CarbonMutedTextBrush" Color="{StaticResource CarbonMutedTextColor}" />
    <SolidColorBrush x:Key="CarbonBorderBrush" Color="{StaticResource CarbonBorderColor}" />
    <SolidColorBrush x:Key="CarbonInputBrush" Color="#111A31" />

    <LinearGradientBrush x:Key="CarbonWindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#07080D" Offset="0" />
        <GradientStop Color="#0D1220" Offset="0.45" />
        <GradientStop Color="#130B1E" Offset="1" />
    </LinearGradientBrush>

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource CarbonTextBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Height" Value="40" />
        <Setter Property="Foreground" Value="{StaticResource CarbonTextBrush}" />
        <Setter Property="Background" Value="{StaticResource CarbonInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CarbonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CaretBrush" Value="{StaticResource CarbonCyanBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Height" Value="40" />
        <Setter Property="Foreground" Value="{StaticResource CarbonTextBrush}" />
        <Setter Property="Background" Value="{StaticResource CarbonInputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CarbonBorderBrush}" />
        <Setter Property="Padding" Value="10,0" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource CarbonCyanBrush}" />
        <Setter Property="Background" Value="{StaticResource CarbonPanelLightBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CarbonBorderBrush}" />
    </Style>

    <Style x:Key="SectionLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CarbonMutedTextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="CardTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionLabelTextStyle}" />

    <Style x:Key="ShellCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#D9121A2E" />
        <Setter Property="BorderBrush" Value="{StaticResource CarbonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="0"
                                  Opacity="0.18"
                                  Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource ShellCardStyle}" />

    <Style x:Key="CompactCardStyle" TargetType="Border" BasedOn="{StaticResource ShellCardStyle}">
        <Setter Property="Padding" Value="14" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="HeroPanelStyle" TargetType="Border" BasedOn="{StaticResource ShellCardStyle}">
        <Setter Property="Padding" Value="30" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1C2949" Offset="0" />
                    <GradientStop Color="#121A2E" Offset="0.46" />
                    <GradientStop Color="#301A42" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#536EE7FF" />
    </Style>

    <Style x:Key="AccentCardStyle" TargetType="Border" BasedOn="{StaticResource ShellCardStyle}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#211A3D" Offset="0" />
                    <GradientStop Color="#121A2E" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavRailButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="116" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{StaticResource CarbonMutedTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#18233D" />
                            <Setter Property="Foreground" Value="{StaticResource CarbonTextBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource CarbonBlueBrush}" />
                        </Trigger>
                        <Trigger Property="Tag" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4CFF4FA3" Offset="0" />
                                        <GradientStop Color="#334DA6FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource CarbonCyanBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CarbonTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource NavRailButtonStyle}" />

    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Foreground" Value="{StaticResource CarbonMutedTextBrush}" />
        <Setter Property="Background" Value="#121A2E" />
        <Setter Property="BorderBrush" Value="{StaticResource CarbonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource CarbonCyanBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CarbonTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LaunchButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="76" />
        <Setter Property="MinWidth" Value="250" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{StaticResource CarbonTextBrush}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder" CornerRadius="18" Padding="28,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource CarbonPinkColor}" Offset="0" />
                                <GradientStop Color="{StaticResource CarbonBlueColor}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="26"
                                              ShadowDepth="0"
                                              Opacity="0.45"
                                              Color="#FF4FA3" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="Foreground" Value="{StaticResource CarbonMutedTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="9">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#1D2945" />
                            <Setter Property="Foreground" Value="{StaticResource CarbonTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
