                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border Grid.Column="2"
                    Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Margin="0,22,22,26"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Friends"
                                       Foreground="{StaticResource CarbonTextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold" />
                            <TextBlock Text="Friends and requests"
                                       Foreground="{StaticResource CarbonMutedTextBrush}"
                                       FontSize="12"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Width="38"
                                Height="38"
                                Style="{StaticResource GhostButtonStyle}"
                                Content="+"
                                Command="{Binding ShowComingSoonCommand}"
                                CommandParameter="Friends system is coming soon." />
                    </Grid>

                    <TextBox Grid.Row="1"
                             Text="Search friends"
                             Foreground="{StaticResource CarbonMutedTextBrush}"
                             Margin="0,18,0,18" />

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="ONLINE FRIENDS" Style="{StaticResource SectionLabelTextStyle}" Margin="0,0,0,12" />
                            <Border Style="{StaticResource CompactCardStyle}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="58" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="10" Background="#334DA6FF" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Astra" Foreground="{StaticResource CarbonTextBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="In Launcher" Foreground="{StaticResource CarbonCyanBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="View"
                                            Command="{Binding ShowComingSoonCommand}"
                                            CommandParameter="Friends system is coming soon." />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource CompactCardStyle}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="58" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="10" Background="#44FF4FA3" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Nyx" Foreground="{StaticResource CarbonTextBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="In-game" Foreground="{StaticResource CarbonBlueBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="View"
                                            Command="{Binding ShowComingSoonCommand}"
                                            CommandParameter="Friends system is coming soon." />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource CompactCardStyle}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="58" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="10" Background="#3026324D" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Vale" Foreground="{StaticResource CarbonTextBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="Idle" Foreground="{StaticResource CarbonMutedTextBrush}" FontSize="12" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="View"
                                            Command="{Binding ShowComingSoonCommand}"
                                            CommandParameter="Friends system is coming soon." />
                                </Grid>
                            </Border>

                            <TextBlock Text="REQUESTS" Style="{StaticResource SectionLabelTextStyle}" Margin="0,14,0,12" />
                            <Border Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Social features coming soon"
                                               Foreground="{StaticResource CarbonTextBrush}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Friend requests will appear here later."
                                               Foreground="{StaticResource CarbonMutedTextBrush}"
                                               FontSize="12"
                                               Margin="0,5,0,0" />
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            Content="Manage"
                                            Command="{Binding ShowComingSoonCommand}"
                                            CommandParameter="Friend requests are coming soon."
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.RowSpan="2"
                  Grid.ColumnSpan="3"
                  Background="#B807080D">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsModalVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource HeroPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding ModalTitle}"
                                   Foreground="{StaticResource CarbonTextBrush}"
                                   FontSize="28"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding ModalMessage}"
                                   Foreground="{StaticResource CarbonMutedTextBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,24" />
                        <Button Style="{StaticResource LaunchButtonStyle}"
                                Content="CLOSE"
                                FontSize="16"
                                Height="52"
                                MinWidth="160"
                                HorizontalAlignment="Right"
                                Command="{Binding CloseModalCommand}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
