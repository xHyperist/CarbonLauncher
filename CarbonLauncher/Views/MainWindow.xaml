<Window x:Class="CarbonLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Carbon Launcher"
        Width="1180"
        Height="720"
        MinWidth="1040"
        MinHeight="640"
        Background="{StaticResource CarbonBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">
    <Border BorderBrush="{StaticResource CarbonBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource CarbonBackgroundBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource CarbonSidebarBrush}"
                    BorderBrush="{StaticResource CarbonBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Carbon"
                                   Foreground="{StaticResource CarbonTextBrush}"
                                   FontSize="28"
                                   FontWeight="Bold" />
                        <TextBlock Text="Launcher v0.1.1"
                                   Foreground="{StaticResource CarbonMutedTextBrush}"
                                   FontSize="13"
                                   Margin="1,4,0,0" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SidebarButtonStyle}"
                                        Content="{Binding Title}"
                                        Tag="{Binding IsActive}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Key}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="3"
                            Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Launcher Status"
                                       Foreground="{StaticResource CarbonMutedTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource CarbonCyanBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Background="{StaticResource CarbonBackgroundBrush}"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="30,0,0,0">
                        <Border Width="10"
                                Height="10"
                                CornerRadius="5"
                                Background="{StaticResource CarbonPinkBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="Carbon Launcher"
                                   Foreground="{StaticResource CarbonTextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,18,0">
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Content="_"
                                Click="Minimize_Click" />
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Content="[]"
                                Click="MaximizeRestore_Click" />
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Content="X"
                                Click="Close_Click" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="30,18,30,30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       Foreground="{StaticResource CarbonTextBrush}"
                                       FontSize="34"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding CurrentPageSubtitle}"
                                       Foreground="{StaticResource CarbonMutedTextBrush}"
                                       FontSize="15"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,26,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="170" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="News / Changelog"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <ItemsControl ItemsSource="{Binding NewsItems}" Margin="0,18,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource CarbonBorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,0,0,14"
                                                    Margin="0,0,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource CarbonTextBrush}"
                                                               FontSize="18"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               Foreground="{StaticResource CarbonMutedTextBrush}"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               Margin="0,7,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="4"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Account"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Text="{Binding AccountName}"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,14,0,0" />
                                <TextBlock Text="Premium Login Coming Soon"
                                           Foreground="{StaticResource CarbonMutedTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource AccentCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Version"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <ComboBox ItemsSource="{Binding Versions}"
                                          SelectedItem="{Binding SelectedVersion}"
                                          DisplayMemberPath="DisplayName"
                                          Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.Column="2"
                                Style="{StaticResource HeroPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Carbon Client"
                                               Foreground="{StaticResource CarbonTextBrush}"
                                               FontSize="28"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Ready when launch flow is connected."
                                               Foreground="{StaticResource CarbonMutedTextBrush}"
                                               FontSize="13"
                                               Margin="0,6,0,0" />
                                </StackPanel>

                                <Button Grid.Row="1"
                                        Content="Launch Carbon Client"
                                        Style="{StaticResource LaunchButtonStyle}"
                                        Command="{Binding LaunchCommand}"
                                        HorizontalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.Column="4"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Settings"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Text="Java, directory, and memory placeholders."
                                           Foreground="{StaticResource CarbonMutedTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0" />
                                <Button Style="{StaticResource SidebarButtonStyle}"
                                        Content="Open Settings"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="Settings"
                                        Margin="0,18,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,26,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Versions">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Available Versions"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <ItemsControl ItemsSource="{Binding Versions}" Margin="0,18,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource CarbonPanelLightBrush}"
                                                    BorderBrush="{StaticResource CarbonBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="18"
                                                    Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="180" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding MinecraftVersion}"
                                                               Foreground="{StaticResource CarbonTextBrush}"
                                                               FontSize="22"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Status}"
                                                               Foreground="{StaticResource CarbonCyanBrush}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,26,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Account">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Account"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Text="{Binding AccountName}"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0,18,0,0" />
                                <TextBlock Text="Premium Login Coming Soon"
                                           Foreground="{StaticResource CarbonMutedTextBrush}"
                                           FontSize="15"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,26,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Java Path"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Text="Auto-detect placeholder"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Minecraft Directory"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Text="%APPDATA%\.minecraft placeholder"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.ColumnSpan="3"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Memory"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Text="RAM allocation placeholder"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,26,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="News">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Changelog / News"
                                           Style="{StaticResource CardTitleTextStyle}" />
                                <ItemsControl ItemsSource="{Binding NewsItems}" Margin="0,18,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource CarbonPanelLightBrush}"
                                                    BorderBrush="{StaticResource CarbonBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="18"
                                                    Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource CarbonTextBrush}"
                                                               FontSize="18"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               Foreground="{StaticResource CarbonMutedTextBrush}"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               Margin="0,7,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
