<Window x:Class="CarbonLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Carbon Launcher"
        Width="1180"
        Height="720"
        MinWidth="1000"
        MinHeight="620"
        Background="{StaticResource CarbonBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{StaticResource CarbonBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource CarbonWindowBackgroundBrush}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ClipToBounds="True">
        <Grid Background="{StaticResource CarbonBackgroundBrush}"
              ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="2"
                    Background="{StaticResource CarbonSidebarBrush}"
                    BorderBrush="{StaticResource CarbonBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Border Width="48"
                                Height="48"
                                CornerRadius="12"
                                Background="{StaticResource CarbonPanelBrush}"
                                BorderBrush="{StaticResource CarbonCyanBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Left">
                            <TextBlock Text="C"
                                       Foreground="{StaticResource CarbonTextBrush}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Carbon Launcher"
                                   Foreground="{StaticResource CarbonTextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="Clean shell"
                                   Foreground="{StaticResource CarbonMutedTextBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SidebarButtonStyle}"
                                        Tag="{Binding IsActive}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Key}">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Left" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  Grid.Row="0"
                  Background="#660D1220"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="28,0,0,0">
                    <TextBlock Text="Carbon Launcher"
                               Foreground="{StaticResource CarbonTextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Border Height="20"
                            Margin="14,0"
                            BorderBrush="{StaticResource CarbonBorderBrush}"
                            BorderThickness="1,0,0,0" />
                    <TextBlock Text="Build v0.1.1-clean"
                               Foreground="{StaticResource CarbonMutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <Border Width="7"
                            Height="7"
                            CornerRadius="4"
                            Background="{StaticResource CarbonCyanBrush}"
                            Margin="16,0,8,0" />
                    <TextBlock Text="Local Mode"
                               Foreground="{StaticResource CarbonMutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <Button Style="{StaticResource WindowButtonStyle}"
                            Content="_"
                            Click="Minimize_Click" />
                    <Button Style="{StaticResource WindowButtonStyle}"
                            Content="[]"
                            Click="MaximizeRestore_Click" />
                    <Button Style="{StaticResource WindowButtonStyle}"
                            Content="X"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1"
                  Grid.Row="1"
                  Margin="28"
                  Background="Transparent"
                  ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding CurrentPageTitle}"
                               Foreground="{StaticResource CarbonTextBrush}"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding CurrentPageSubtitle}"
                               Foreground="{StaticResource CarbonMutedTextBrush}"
                               FontSize="14"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Grid Grid.Row="2"
                      Background="Transparent"
                      ClipToBounds="True">
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource HeroPanelStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Home">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Carbon Client"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontSize="42"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedVersionText, StringFormat=Selected Version: {0}}"
                                           Foreground="{StaticResource CarbonCyanBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="This clean launcher shell is ready for future launch, account, and update systems."
                                           Foreground="{StaticResource CarbonMutedTextBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           MaxWidth="620"
                                           Margin="0,14,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal">
                                <Button Style="{StaticResource LaunchButtonStyle}"
                                        Content="LAUNCH"
                                        Command="{Binding LaunchCommand}" />
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Content="CHANGE VERSION"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="Versions"
                                        Margin="16,19,0,0"
                                        MinWidth="150" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Versions">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="Available Versions"
                                       Style="{StaticResource SectionLabelTextStyle}" />
                            <ItemsControl ItemsSource="{Binding Versions}" Margin="0,16,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CompactCardStyle}"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding MinecraftVersion}"
                                                               Foreground="{StaticResource CarbonTextBrush}"
                                                               FontSize="22"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="{StaticResource CarbonMutedTextBrush}"
                                                               FontSize="13"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Content="Select"
                                                        Command="{Binding DataContext.SelectVersionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        MinWidth="110" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Account">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel MaxWidth="520"
                                    HorizontalAlignment="Left">
                            <TextBlock Text="Guest Username"
                                       Style="{StaticResource SectionLabelTextStyle}" />
                            <TextBox Text="{Binding GuestUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,10,0,18" />
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Content="Save"
                                        Command="{Binding SaveAccountCommand}"
                                        MinWidth="120" />
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Content="Microsoft Login"
                                        Command="{Binding ShowComingSoonCommand}"
                                        CommandParameter="Microsoft login is coming soon."
                                        MinWidth="160"
                                        Margin="12,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel MaxWidth="640"
                                    HorizontalAlignment="Left">
                            <TextBlock Text="Java Runtime"
                                       Style="{StaticResource SectionLabelTextStyle}" />
                            <Grid Margin="0,10,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Java Status"
                                           Foreground="{StaticResource CarbonMutedTextBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding JavaStatusText}"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2"
                                           Text="Java Version"
                                           Foreground="{StaticResource CarbonMutedTextBrush}" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding JavaVersionText}"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Row="4"
                                           Text="Java Source"
                                           Foreground="{StaticResource CarbonMutedTextBrush}" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Text="{Binding JavaSourceText}"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Row="6"
                                           Text="Java Path"
                                           Foreground="{StaticResource CarbonMutedTextBrush}" />
                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           Text="{Binding CurrentJava.JavaPath}"
                                           Foreground="{StaticResource CarbonTextBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="8"
                                        Grid.Column="1"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Content="Detect Java"
                                        Command="{Binding DetectJavaCommand}"
                                        HorizontalAlignment="Left"
                                        MinWidth="130" />
                            </Grid>
                            <TextBlock Text="Java Path"
                                       Style="{StaticResource SectionLabelTextStyle}" />
                            <TextBox Text="{Binding JavaPath, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,10,0,18" />
                            <TextBlock Text="Minecraft Directory"
                                       Style="{StaticResource SectionLabelTextStyle}" />
                            <TextBox Text="{Binding MinecraftDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,10,0,18" />
                            <TextBlock Text="Allocated Memory MB"
                                       Style="{StaticResource SectionLabelTextStyle}" />
                            <TextBox Text="{Binding AllocatedMemoryMb, UpdateSourceTrigger=PropertyChanged}"
                                     Width="220"
                                     HorizontalAlignment="Left"
                                     Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.RowSpan="2"
                  Grid.ColumnSpan="2"
                  Background="#B807080D">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsModalVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding ModalTitle}"
                                   Foreground="{StaticResource CarbonTextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding ModalMessage}"
                                   Foreground="{StaticResource CarbonMutedTextBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,24" />
                        <Button Style="{StaticResource GhostButtonStyle}"
                                Content="Close"
                                Command="{Binding CloseModalCommand}"
                                MinWidth="120"
                                HorizontalAlignment="Right" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
